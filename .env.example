# Public (browser + server)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay (server + publishable key id for checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_secret

# Stripe Checkout (optional — if set with Razorpay, donors choose provider)
STRIPE_SECRET_KEY=sk_live_xxxxx
# Webhook signing secret from Stripe Dashboard → Webhooks (endpoint: /api/v1/payments/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Supabase service role — payments finalization & volunteer counts (keep secret, server-only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq (server-only) — captions, moderation, CSR summaries
GROQ_API_KEY=gsk_xxxxx

# Resend — volunteer event confirmation emails (https://resend.com)
RESEND_API_KEY=re_xxxxx
# No owned domain: use Resend’s test sender (limited recipients — see resend.com docs). Own domain: Name <you@yourdomain.com>
RESEND_FROM_EMAIL="Soul Space <onboarding@resend.dev>"
